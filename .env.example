# AgentsX Configuration Example
# Copy this file to .env and fill in your API keys.

# Default model to use
AGENTSX_MODEL_NAME=gpt-4o

# API key for the default provider (or use provider-specific keys below)
AGENTSX_API_KEY=

# Optional custom API base URL
AGENTSX_API_BASE=

# Provider-specific keys (override AGENTSX_API_KEY when set)
AGENTSX_OPENAI_API_KEY=
AGENTSX_OPENAI_API_BASE=

AGENTSX_ANTHROPIC_API_KEY=
AGENTSX_ANTHROPIC_API_BASE=

# Agent behavior
AGENTSX_MAX_STEPS=25
AGENTSX_SYSTEM_PROMPT=You are a helpful AI assistant.

# Session storage (empty = ~/.agentsx/sessions/)
AGENTSX_SESSION_DIR=

# Security policy: allow, prompt, or forbidden
AGENTSX_POLICY_DEFAULT=prompt

# Tool execution timeout in seconds
AGENTSX_TOOL_TIMEOUT=30

# Provider retry settings
AGENTSX_PROVIDER_RETRY_COUNT=3
AGENTSX_PROVIDER_RETRY_BASE_DELAY=1.0

# Agent loop wall-clock timeout in seconds (0 = disabled)
AGENTSX_LOOP_TIMEOUT=0

# Maximum tool output characters (0 = no limit)
AGENTSX_MAX_TOOL_OUTPUT=50000
